{
  "name": "zotero-pdf2md",
  "type": "module",
  "version": "0.1.0",
  "description": "Zotero plugin for PDF to Markdown, translation, and HTML preview",
  "config": {
    "addonName": "zotero-pdf2md",
    "addonID": "zotero-pdf2md@yyds.dev",
    "addonRef": "zoteroPdf2md",
    "addonInstance": "ZoteroPdf2md",
    "prefsPrefix": "extensions.zotero.zoteroPdf2md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CrushDemo01/zotero-pdf2md.git"
  },
  "author": "CrushDemo01",
  "bugs": {
    "url": "https://github.com/CrushDemo01/zotero-pdf2md/issues"
  },
  "homepage": "https://github.com/CrushDemo01/zotero-pdf2md#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "katex": "^0.16.45",
    "markdown-it": "^14.1.1",
    "markdown-it-texmath": "^1.0.0",
    "zotero-plugin-toolkit": "^5.1.2"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.9",
    "chai": "^6.2.2",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.6",
    "zotero-types": "^4.1.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
